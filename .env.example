# --- NETWORK CONFIGURATION ---
# If you want to access the application from other devices on your local network (LAN),
# replace "localhost" with your machine's LAN IP address (e.g., 192.168.1.50).
LAN_IP=localhost

# --- FRONTEND CONFIGURATION ---
VITE_API_URL=http://${LAN_IP}:8000

# --- BACKEND CONFIGURATION ---
# Authorized CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:41481,http://${LAN_IP}:41481
OLLAMA_HOST=http://host.docker.internal:11434
